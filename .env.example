# 番茄小说阅读器环境变量示例
# 复制为 .env 后按你的环境修改

# =========================
# 基础应用配置
# =========================
FLASK_APP=app.py
FLASK_ENV=production
FLASK_LOG_LEVEL=INFO
FLASK_SECRET_KEY=please-change-this-flask-secret-key-32chars
JWT_SECRET_KEY=please-change-this-jwt-secret-key-32chars
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
SQLALCHEMY_ECHO=False
TZ=Asia/Shanghai

# 内部 API 模式（默认推荐本地/内网使用）
INTERNAL_API_MODE=true
INTERNAL_API_USER_ID=1
INTERNAL_API_PASSWORD=internal-api-disabled
# 直接用 python 运行 backend/app.py 时控制是否自动建表
AUTO_CREATE_TABLES=false
RUN_LEGACY_RUNTIME_SCHEMA_PATCHES=false

# =========================
# 数据库配置
# =========================
# 直接本机运行 backend 时使用 DATABASE_URL
# PostgreSQL 示例：postgresql+psycopg://fanqie_user:fanqie_password@127.0.0.1:5432/fanqie_db
# SQLite 示例：sqlite:///backend/data/fanqie.db
DATABASE_URL=

# Docker Compose 中 backend / celery_worker 优先读取 DATABASE_URL_INTERNAL
# 留空时会自动使用 compose 内置 PostgreSQL：postgresql+psycopg://fanqie_user:fanqie_password@postgres:5432/fanqie_db
DATABASE_URL_INTERNAL=

# 主数据库不可达时的回退策略；留空时使用内置默认值
# 直接本机运行可写：sqlite:///backend/data/fanqie.db
# Docker Compose 内默认回退：sqlite:////app/data/fanqie.db
DATABASE_FALLBACK_URL=
DATABASE_FALLBACK_ON_FAILURE=true

# Docker Compose 中 backend / celery_worker 的自动建表开关
# 留空时会使用 compose 默认值 true
AUTO_CREATE_TABLES_INTERNAL=

# 仅在未设置 DATABASE_URL / DATABASE_URL_INTERNAL 时使用旧版 DB_* MySQL 拼接逻辑
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fanqie_db
DB_USER=fanqie_user
DB_PASSWORD=fanqie_password
DB_ROOT_PASSWORD=root_password

# =========================
# Celery / Redis 配置
# =========================
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# =========================
# 路径与跨域
# =========================
DATA_BASE_PATH=backend/data
NOVEL_SAVE_PATH=backend/data/novel_downloads
NOVEL_STATUS_PATH=backend/data/novel_status
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:26013,http://127.0.0.1:26013

# =========================
# 下载器配置
# =========================
NOVEL_MAX_WORKERS=3
NOVEL_REQUEST_TIMEOUT=20
NOVEL_MAX_RETRIES=3
NOVEL_MIN_WAIT_TIME=2000
NOVEL_MAX_WAIT_TIME=5000
NOVEL_MIN_CONNECT_TIMEOUT=3.1
NOVEL_FORMAT=epub
NOVEL_BULK_FILES=false
NOVEL_AUTO_CLEAR_DUMP=true

# 下载源开关
NOVEL_USE_THIRDPARTY_API=true
NOVEL_USE_OFFICIAL_API=false
NOVEL_USE_PROXY_API=false
NOVEL_USE_CUSTOM_CONTENT_API=true
NOVEL_CUSTOM_CONTENT_API_BASE=http://117.24.4.119:11451/fqy/api_v2.php
FQ_API_KEY=

# 官方 API / IID 配置（使用官方链路时需要）
NOVEL_IID=
NOVEL_IID_SPAWN_TIME=

# 可选：自定义第三方 API 列表，逗号分隔
NOVEL_API_ENDPOINTS=https://api.cenguigui.cn/api/tomato

# =========================
# 前端本地开发代理（可选）
# =========================
# Vite 本地开发默认代理到 127.0.0.1:5000；如需改动可覆盖以下变量
VITE_API_PROXY_TARGET=http://127.0.0.1:5000
VITE_SOCKET_PROXY_TARGET=ws://127.0.0.1:5000

# =========================
# 说明
# =========================
# 1. 不要在配置值后面直接写注释，例如 KEY=value # comment
# 2. 布尔值统一使用 true / false
# 3. NOVEL_MIN_WAIT_TIME / NOVEL_MAX_WAIT_TIME 单位为毫秒
# 4. 内部 API 模式适合本地和内网；公网环境建议关闭 INTERNAL_API_MODE 并启用 JWT 登录流
